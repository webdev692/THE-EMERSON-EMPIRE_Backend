    "express-rate-limit": "8.5.2",
    "express-validator": "7.3.2",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "multer": "2.1.1",
    "nodemailer": "8.0.10",
    "pdf-lib": "1.17.1",
    "pdf-parse": "1.1.4",

NODE_ENV=development
PORT=3000

# Supabase/Postgres connection string.
# Use the pooled connection string in production if available.
# Never commit a real DATABASE_URL value.
DATABASE_URL=postgresql://username:password@host:5432/database

# Comma-separated origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8888,https://theemerson.netlify.app,https://emersonagency.netlify.app,https://emersonprofessionaldevelopment.netlify.app,https://epdg.netlify.app

PUBLIC_CREDITS_ENABLED=true
AGENCY_MODULE_ENABLED=true
EPDG_MODULE_ENABLED=true
CERTIFICATE_VERIFICATION_ENABLED=true

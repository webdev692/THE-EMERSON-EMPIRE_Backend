# Runtime mode and listener port.
NODE_ENV=
PORT=

# PostgreSQL connection configuration.
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=
DB_CONNECTION_TIMEOUT_MS=
DB_STATEMENT_TIMEOUT_MS=

# Authentication signing secret and browser application origin.
JWT_SECRET=
FRONTEND_URL=

# Explicit comma-separated browser origin allowlist.
CORS_ORIGINS=

# Transactional email provider configuration.
RESEND_API_KEY=
SMTP_FROM=

# Supabase project origin used to validate existing stored-document URLs.
SUPABASE_URL=

# Server-only key reserved for reviewed private storage workflows. Current
# anonymous upload, private submission, and certificate issuance writes remain
# disabled; never expose this variable to a browser build.
SUPABASE_SERVICE_ROLE_KEY=

# Certificate integrity signing secret.
CERT_SIGNING_SECRET=

# Manual-only migration acknowledgement; never enable on application startup.
ALLOW_DATABASE_MIGRATIONS=

# Manual super-administrator seed inputs.
SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

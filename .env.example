# Runtime mode and listener port.
NODE_ENV=
PORT=

# Server-side PostgreSQL connection string.
DATABASE_URL=

# Database TLS and bounded-wait controls. Production always verifies the
# server certificate; DB_SSL cannot disable verification there.
DB_SSL=
DB_CONNECTION_TIMEOUT_MS=
DB_STATEMENT_TIMEOUT_MS=

# Explicit comma-separated browser origin allowlist.
CORS_ALLOWED_ORIGINS=

# Public foundation feature switches; each feature is disabled unless true.
PUBLIC_CREDITS_ENABLED=
AGENCY_MODULE_ENABLED=
CERTIFICATE_VERIFICATION_ENABLED=
